{
  "version": "2.0.0",
  "options": {
    "shell": {
      "executable": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command"
      ]
    },
    "env": {
      "JAVA_HOME": "C:\\NoBackup\\Coding\\AndroidBuild\\jdk-21.0.5+11",
      "ANDROID_HOME": "C:\\NoBackup\\Coding\\AndroidBuild\\android-sdk",
      "ANDROID_SDK_ROOT": "C:\\NoBackup\\Coding\\AndroidBuild\\android-sdk",
      "PATH": "C:\\NoBackup\\Coding\\AndroidBuild\\jdk-21.0.5+11\\bin;C:\\NoBackup\\Coding\\AndroidBuild\\gradle-8.10.2\\bin;C:\\NoBackup\\Coding\\AndroidBuild\\android-sdk\\platform-tools;C:\\NoBackup\\Coding\\AndroidBuild\\android-sdk\\emulator;${env:PATH}"
    }
  },
  "tasks": [
    {
      "label": "Android: Build Debug",
      "type": "shell",
      "command": "gradle :app:assembleDebug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Start Emulator (WardrobeApi36)",
      "type": "shell",
      "command": "if (-not (adb devices | Select-String 'emulator-')) { Start-Process emulator -ArgumentList '-avd WardrobeApi36'; Start-Sleep -Seconds 3 }; adb wait-for-device; while ((adb shell getprop sys.boot_completed).Trim() -ne '1') { Start-Sleep -Seconds 2 }; Write-Host 'Emulator booted.'",
      "problemMatcher": []
    },
    {
      "label": "Android: Install Debug",
      "type": "shell",
      "command": "gradle :app:installDebug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Android: Start Emulator (WardrobeApi36)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Android: Run on Emulator",
      "type": "shell",
      "command": "adb shell am start -n com.vestis.wardrobe/.MainActivity",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Android: Install Debug"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Run Debug (Wait for Debugger)",
      "type": "shell",
      "command": "adb shell am start -D -n com.vestis.wardrobe/.MainActivity",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Android: Install Debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "Android: Prepare Java Debug Attach",
      "type": "shell",
      "command": "$pkg = 'com.vestis.wardrobe'; $pid = (adb shell pidof -s $pkg).Trim(); if (-not $pid) { Write-Error \"Could not find running pid for $pkg. Run 'Android: Run Debug (Wait for Debugger)' first.\"; exit 1 }; adb forward --remove tcp:8700 2>$null; adb forward tcp:8700 jdwp:$pid; Write-Host \"Forwarded localhost:8700 -> jdwp:$pid ($pkg)\"",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Android: Run Debug (Wait for Debugger)"
      ],
      "problemMatcher": []
    }
  ]
}
